---
import Footer from '../Footer.astro';
import { activities } from '../../data/activities.js';
import '../../styles/components/home/activity-section.css';
---

<section class="activity-section" id="page-3">
  <div class="news-header">
    <h2>最新动态</h2>
    <p>了解网协最新活动与资讯</p>
  </div>
  
  <div class="cards-wrapper">
    <button class="scroll-btn scroll-btn-left" id="scroll-btn-left" aria-label="向左滚动">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    
    <div class="cards-container" id="activity-cards-container" tabindex="0">
      {activities.map((activity, index) => (
        <div 
          class="activity-card"
          style={`--card-color: ${activity.color}`}
          data-index={index}
        >
          <span class="card-category">{activity.category}</span>
          <span class="card-date">{activity.date}</span>
          <h3 class="card-title">{activity.title}</h3>
          <p class="card-desc">{activity.description}</p>
        </div>
      ))}
    </div>
    
    <button class="scroll-btn scroll-btn-right" id="scroll-btn-right" aria-label="向右滚动">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
  
  <div class="footer-wrapper">
    <Footer />
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('activity-cards-container');
    const btnLeft = document.getElementById('scroll-btn-left');
    const btnRight = document.getElementById('scroll-btn-right');
    if (!container) return;
    
    const cards = container.querySelectorAll('.activity-card');
    const totalCards = cards.length;
    
    // 更新按钮可见性
    function updateButtonVisibility() {
      const { scrollLeft, scrollWidth, clientWidth } = container;
      const canScrollLeft = scrollLeft > 0;
      const canScrollRight = scrollLeft < scrollWidth - clientWidth - 10;
      
      btnLeft.style.opacity = canScrollLeft ? '1' : '0';
      btnLeft.style.pointerEvents = canScrollLeft ? 'auto' : 'none';
      btnRight.style.opacity = canScrollRight ? '1' : '0';
      btnRight.style.pointerEvents = canScrollRight ? 'auto' : 'none';
    }
    
    // 绑定按钮点击事件
    btnLeft.addEventListener('click', () => {
      container.scrollBy({ left: -320, behavior: 'smooth' });
    });
    
    btnRight.addEventListener('click', () => {
      container.scrollBy({ left: 320, behavior: 'smooth' });
    });
    
    // 监听滚动事件更新按钮状态
    container.addEventListener('scroll', updateButtonVisibility);
    
    // 初始化按钮状态
    updateButtonVisibility();
    
    container.addEventListener('wheel', (e) => {
      const isHorizontalScroll = e.shiftKey || Math.abs(e.deltaX) > Math.abs(e.deltaY);
      if (!isHorizontalScroll) return;
      
      e.preventDefault();
      
      const scrollAmount = e.deltaX !== 0 ? e.deltaX : e.deltaY;
      
      if (scrollAmount > 30) {
        container.scrollBy({ left: 300, behavior: 'smooth' });
      } else if (scrollAmount < -30) {
        container.scrollBy({ left: -300, behavior: 'smooth' });
      }
    }, { passive: false });
    
    container.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        container.scrollBy({ left: 320, behavior: 'smooth' });
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        container.scrollBy({ left: -320, behavior: 'smooth' });
      }
    });
    
    let touchStartX = 0;
    let touchEndX = 0;
    
    container.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    container.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          container.scrollBy({ left: 320, behavior: 'smooth' });
        } else {
          container.scrollBy({ left: -320, behavior: 'smooth' });
        }
      }
    }, { passive: true });
  });
</script>