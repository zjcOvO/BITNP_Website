---
// HeroSection.astro - 首页主视觉区域
// 左侧：协会Logo（带装饰胶带和头像）
// 右侧：大标题 + 英文副标题 + 标语 + 服务卡片(鼠标悬停Logo时变为简介)
import '../../styles/components/home/hero.css';
import { services } from '../../data/services.js';
import TapeEffect from './TapeEffect.astro';

const BASE_URL = import.meta.env.BASE_URL;
const tapeText = "网络无限 开拓不懈 —— 网络开拓者协会 Net Pioneer Association of BIT";
---

<section class="hero-section">
  <div class="hero-container">
    <!-- 左侧：Logo区域（悬停时触发右侧内容变换） -->
    <div class="hero-left">
      <div class="logo-wrapper" id="logo-trigger">
        <!-- 上方小头像装饰 -->
        <div class="avatar-decoration avatar-top">
          <img src={`${BASE_URL || '/'}images/avatar-top.png`} alt="装饰头像" />
        </div>
        
        <!-- 协会圆形Logo -->
        <div class="association-logo">
          <img src={`${BASE_URL || '/'}images/bitnp-logo.png`} alt="北京理工大学网络开拓者协会" />
        </div>
        
        <!-- 左下方小图标装饰 -->
        <div class="avatar-decoration avatar-bottom">
          <img src={`${BASE_URL || '/'}images/avatar-bottom.png`} alt="装饰图标" />
        </div>
        
        <!-- 交叉装饰胶带 - 空间缩放效果 -->
        <TapeEffect text={tapeText} rotation="-15" />
        <TapeEffect text={tapeText} rotation="10" />
      </div>
    </div>
    
    <!-- 右侧：标题与内容区域 -->
    <div class="hero-right">
      <h1 class="hero-title">网络开拓者协会</h1>
      <h2 class="hero-subtitle">Net Pioneer<br>Association of BIT</h2>
      
      <div class="hero-slogan">
        <span class="slogan-text">网络无限开拓不懈</span>
        <span class="slogan-divider">||||||||||||||||||||||||||||||</span>
      </div>
      
        <!-- 服务卡片/简介切换区域 -->
        <div class="hero-content-switcher">
          <!-- 服务卡片组（悬停Logo时变为简介） -->
          <div class="hero-cards" id="hero-cards">
            {services.map((service) => (
              <a href={`${BASE_URL || ''}${service.href.startsWith('/') ? service.href.slice(1) : service.href}`} class={`service-card service-card--${service.variant}`}>
                <div class="card-content">
                  <h3 class="card-title">{service.title}</h3>
                  <p class="card-description">{service.description}</p>
                </div>
                {service.decorations ? (
                  <div class="card-decorations">
                    <span class="dot dot-pink"></span>
                    <span class="dot dot-orange"></span>
                    <span class="pill pill-yellow"></span>
                    <span class="pill pill-pink"></span>
                  </div>
                ) : null}
              </a>
            ))}
          </div>
        
        <!-- 简介段落（默认隐藏，悬停Logo时显示） -->
        <div class="hero-description" id="hero-description">
        <p>
          &emsp;&emsp;<a href={BASE_URL || '/'} class="highlight-link">网络开拓者协会</a>
          是北京理工大学校内规模最大的学生组织之一，本着 "网络无限，开拓不懈" 的精神，不断摸索、引领校园网络建设，后成为校团委领导的全校唯一 IT 类学生组织。
        </p>
        <p>
          &emsp;&emsp;如今，网协各项规章制度和硬件设备基本完善，成长为北理最大的
          <a href={`${BASE_URL || '/'}services`} class="highlight-link">网络服务提供</a>
          团体，拥有每日最高的<span class="highlight">访问量</span>。
          从学校学生工作，到日常娱乐服务，协会的服务范围仍然在继续扩大。
          同时，协会自身也在不断努力增强实力，拓展业务。
        </p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const logoTrigger = document.getElementById('logo-trigger');
    const heroCards = document.getElementById('hero-cards');
    const heroDescription = document.getElementById('hero-description');
    const associationLogo = logoTrigger?.querySelector('.association-logo');
    const tapes = logoTrigger?.querySelectorAll('.tape-effect');
    
    let isLocked = false;
    let currentLogoX = 0;
    let currentLogoY = 0;
    let targetLogoX = 0;
    let targetLogoY = 0;
    let animationId = null;
    
    // Easing function for smooth return
    const easeOut = (t) => 1 - Math.pow(1 - t, 3);
    let returnProgress = 0;
    let startReturnX = 0;
    let startReturnY = 0;
    let isReturning = false;
    
    const animate = () => {
      if (isReturning) {
        returnProgress += 0.02;
        if (returnProgress >= 1) {
          currentLogoX = 0;
          currentLogoY = 0;
          isReturning = false;
          returnProgress = 0;
        } else {
          const eased = easeOut(returnProgress);
          currentLogoX = startReturnX * (1 - eased);
          currentLogoY = startReturnY * (1 - eased);
        }
      } else {
        // Smooth follow with lerp
        currentLogoX += (targetLogoX - currentLogoX) * 0.15;
        currentLogoY += (targetLogoY - currentLogoY) * 0.15;
      }
      
      if (associationLogo) {
        associationLogo.style.transform = `translate(${currentLogoX}px, ${currentLogoY}px)`;
      }
      
      if (tapes && tapes.length > 0) {
        const tapeDisplacement = 0.8;
        tapes.forEach(tape => {
          tape.style.transform = `translate(-50%, -50%) translate(${currentLogoX * tapeDisplacement}px, ${currentLogoY * tapeDisplacement}px) rotate(${tape.dataset.rotation}deg)`;
        });
      }
      
      animationId = requestAnimationFrame(animate);
    };
    
    animate();
    
    if (logoTrigger && heroCards && heroDescription) {
      // 点击切换固定状态
      logoTrigger.addEventListener('click', function(e) {
        // 排除头像和logo自身的点击，仅当点击wrapper空白区域时触发
        if (e.target.closest('.avatar-decoration') || e.target.closest('.association-logo')) {
          return;
        }
        isLocked = !isLocked;
        if (isLocked) {
          heroCards.classList.add('hidden');
          heroDescription.classList.add('visible');
        } else {
          heroCards.classList.remove('hidden');
          heroDescription.classList.remove('visible');
        }
      });
      
      // 鼠标移动计算偏移
      logoTrigger.addEventListener('mousemove', function(e) {
        const rect = logoTrigger.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        
        const mouseX = e.clientX;
        const mouseY = e.clientY;
        
        // 计算鼠标相对于中心的偏移
        const offsetX = mouseX - centerX;
        const offsetY = mouseY - centerY;
        
        // Logo向相反方向移动，最大偏移15px
        const maxOffset = 15;
        const distance = Math.sqrt(offsetX * offsetX + offsetY * offsetY);
        const scale = Math.min(distance / 200, 1);
        
        targetLogoX = -(offsetX / distance) * maxOffset * scale || 0;
        targetLogoY = -(offsetY / distance) * maxOffset * scale || 0;
        
        // 停止归位动画
        isReturning = false;
        returnProgress = 0;
      });
      
      // 鼠标离开时触发缓慢归位，同时如果未锁定则恢复卡片显示
      logoTrigger.addEventListener('mouseleave', function() {
        startReturnX = currentLogoX;
        startReturnY = currentLogoY;
        isReturning = true;
        returnProgress = 0;
        
        if (!isLocked) {
          heroCards.classList.remove('hidden');
          heroDescription.classList.remove('visible');
        }
      });

      // 鼠标进入时触发卡片隐藏
      logoTrigger.addEventListener('mouseenter', function() {
        if (!isLocked) {
          heroCards.classList.add('hidden');
          heroDescription.classList.add('visible');
        }
      });
    }
  });
</script>
