---
import { departments } from '../../data/departments.js';
import '../../styles/components/home/department-cards.css';

const allDepts = departments;
---

<div class="department-cards-wrapper" id="department-cards-wrapper" tabindex="0">
  <div class="dept-names-column">
    {allDepts.map((dept, index) => (
      <div 
        class={`dept-name-item ${index === 0 ? 'active' : ''}`}
        data-dept={dept.id}
        data-index={index}
        style={`--dept-color: ${dept.color}`}
      >
        <span class="vertical-text">{dept.name}&emsp;</span>
        <div class="dept-indicator"></div>
      </div>
    ))}
  </div>
  
  <div class="dept-content-area" id="dept-content-area">
    <div class="cards-scroll-container" id="cards-scroll-container">
      {allDepts.map((dept, index) => (
        <div 
          class={`dept-content-section ${index === 0 ? 'active' : ''}`}
          data-dept={dept.id}
          data-index={index}
        >
          <div class="cards-front">
            <div class="cards-grid">
              {dept.activities.map((activity, actIndex) => (
                <div 
                  class="activity-card"
                  style={`--card-delay: ${actIndex * 0.1}s`}
                >
                  <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                    </svg>
                  </div>
                  <h4 class="card-title">{activity.title}</h4>
                  <p class="card-desc">{activity.description.substring(0, 50)}...</p>
                </div>
              ))}
            </div>
          </div>
          
          <div class="cards-description">
            <div class="description-content" style={`color: ${dept.color}`}>
              {dept.activities.map((activity) => (
                <div class="desc-item">
                  <span class="desc-title">{activity.title}</span>
                  <span class="desc-text">{activity.description}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.getElementById('department-cards-wrapper');
    const contentArea = document.getElementById('dept-content-area');
    const deptNameItems = wrapper?.querySelectorAll('.dept-name-item');
    const deptContentSections = wrapper?.querySelectorAll('.dept-content-section');
    
    if (!wrapper || !contentArea) return;
    
    let currentIndex = 0;
    const totalSections = deptContentSections?.length || 0;
    let isAnimating = false;
    let isHovering = false;
    
    function switchToDepartment(index, animate = true) {
      if (isAnimating || index < 0 || index >= totalSections) return;
      
      if (index === currentIndex && document.querySelector('.dept-content-section.active')) {
        return;
      }
      
      isAnimating = true;
      currentIndex = index;
      
      deptNameItems?.forEach((item) => {
        item.classList.remove('active');
      });
      
      deptContentSections?.forEach((section) => {
        section.classList.remove('active');
      });
      
      deptNameItems?.[index]?.classList.add('active');
      deptContentSections?.[index]?.classList.add('active');
      
      window.dispatchEvent(new CustomEvent('department-change', { 
        detail: { activeDept: deptNameItems?.[index]?.dataset.dept || 'chairman' } 
      }));
      
      setTimeout(() => {
        isAnimating = false;
      }, 400);
    }
    
    let descriptionTimeout = null;
    
    deptNameItems?.forEach((item, index) => {
      item.addEventListener('mouseenter', () => {
        if (descriptionTimeout) {
          clearTimeout(descriptionTimeout);
          descriptionTimeout = null;
        }
        
        deptContentSections?.forEach((section) => {
          section.classList.remove('show-description');
        });
        
        if (index !== currentIndex) {
          switchToDepartment(index, true);
          descriptionTimeout = setTimeout(() => {
            deptContentSections?.forEach((section, i) => {
              if (i === index) {
                section.classList.add('show-description');
              }
            });
          }, 600);
        } else {
          deptContentSections?.forEach((section, i) => {
            if (i === currentIndex) {
              section.classList.add('show-description');
            }
          });
        }
        
        isHovering = true;
        item.classList.add('hovering');
      });
      
      item.addEventListener('mouseleave', () => {
        if (descriptionTimeout) {
          clearTimeout(descriptionTimeout);
          descriptionTimeout = null;
        }
        
        isHovering = false;
        item.classList.remove('hovering');
        
        deptContentSections?.forEach((section) => {
          section.classList.remove('show-description');
        });
      });
      
      item.addEventListener('click', () => {
        if (descriptionTimeout) {
          clearTimeout(descriptionTimeout);
          descriptionTimeout = null;
        }
        switchToDepartment(index);
      });
    });
    
    let scrollTimeout;
    contentArea.addEventListener('wheel', (e) => {
      if (isHovering) return;
      
      const isHorizontalScroll = e.shiftKey || Math.abs(e.deltaX) > Math.abs(e.deltaY);
      if (!isHorizontalScroll) return;
      
      e.preventDefault();
      
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const isScrollingRight = e.deltaX > 30 || (e.shiftKey && e.deltaY > 30);
        const isScrollingLeft = e.deltaX < -30 || (e.shiftKey && e.deltaY < -30);
        
        if (isScrollingRight) {
          switchToDepartment((currentIndex + 1) % totalSections);
        } else if (isScrollingLeft) {
          switchToDepartment((currentIndex - 1 + totalSections) % totalSections);
        }
      }, 50);
    }, { passive: false });
    
    wrapper.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        switchToDepartment((currentIndex + 1) % totalSections);
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        switchToDepartment((currentIndex - 1 + totalSections) % totalSections);
      }
    });
    
    let touchStartX = 0;
    let touchEndX = 0;
    
    contentArea.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    contentArea.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          switchToDepartment((currentIndex + 1) % totalSections);
        } else {
          switchToDepartment((currentIndex - 1 + totalSections) % totalSections);
        }
      }
    }, { passive: true });
    
    window.addEventListener('department-init', (e) => {
      const deptIndex = Array.from(deptNameItems || []).findIndex(
        item => item.dataset.dept === e.detail.activeDept
      );
      if (deptIndex >= 0) {
        switchToDepartment(deptIndex, false);
      }
    });
    
    window.addEventListener('department-change', (e) => {
      const deptIndex = Array.from(deptNameItems || []).findIndex(
        item => item.dataset.dept === e.detail.activeDept
      );
      if (deptIndex >= 0 && deptIndex !== currentIndex) {
        switchToDepartment(deptIndex);
      }
    });
    
    setTimeout(() => {
      switchToDepartment(0, false);
    }, 100);
  });
</script>