---
// ThemeToggle 组件 - 亮暗模式切换开关
import moon from '../assets/moon.svg';
import sun from '../assets/sun.svg';
import { Image } from 'astro:assets';
import '../styles/components/theme-toggle.css';
---

<!-- 亮/暗模式切换开关 -->
<div class="theme-toggle">
  <input 
    type="checkbox" 
    id="theme-toggle-checkbox" 
    class="theme-toggle-checkbox" 
    aria-label="切换亮/暗模式"
  />
  <label for="theme-toggle-checkbox" class="theme-toggle-label">
    <span style="display:none;">切换亮/暗模式</span>
    <span class="theme-toggle-track">
      <span class="theme-toggle-thumb">
        <!-- 月亮图标（暗模式） -->
        <Image 
          src={moon} 
          alt="暗模式" 
          width={16}
          height={16}
          class="theme-toggle-icon moon-icon" 
          loading={'eager'}
        />
        <!-- 太阳图标（亮模式） -->
        <Image 
          src={sun} 
          alt="亮模式" 
          width={16}
          height={16}
          loading={'eager'}
          class="theme-toggle-icon sun-icon" 
        />
      </span>
    </span>
  </label>
</div>


<script is:inline>
  // 暗模式切换功能 - 使用 data-theme 属性
  (function() {
    // 获取 HTML 元素
    const htmlElement = document.documentElement;
    const themeToggleCheckbox = document.getElementById('theme-toggle-checkbox');
    
    // 检查本地存储的暗模式设置
    const savedDarkMode = localStorage.getItem('darkMode') === 'true';
    
    // 初始化状态
    if (savedDarkMode) {
      htmlElement.setAttribute('data-theme', 'dark');
      if (themeToggleCheckbox) {
        themeToggleCheckbox.checked = true;
      }
    } else {
      htmlElement.setAttribute('data-theme', 'light');
      if (themeToggleCheckbox) {
        themeToggleCheckbox.checked = false;
      }
    }
    
    // 为暗模式切换开关添加事件监听
    if (themeToggleCheckbox) {
      themeToggleCheckbox.addEventListener('change', function() {
        const isDark = this.checked;
        if (isDark) {
          htmlElement.setAttribute('data-theme', 'dark');
        } else {
          htmlElement.setAttribute('data-theme', 'light');
        }
        localStorage.setItem('darkMode', isDark);
        
        // 更新 checkbox 的 aria-label
        this.setAttribute('aria-label', 
          isDark ? '切换到亮模式' : '切换到暗模式'
        );
      });
    }
    
    // 添加一个简单的日志来调试
    console.log('ThemeToggle initialized. Current theme:', htmlElement.getAttribute('data-theme'));
  })();
</script>
