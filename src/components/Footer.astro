---
// Footer 组件
import '../styles/components/footer.css';

const BASE_URL = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-section">
      <h3 class="footer-title">BITNP 网络技术协会</h3>
      <p class="footer-description">
        网络无限 · 开拓不懈
      </p>
    </div>
    
    <div class="footer-section">
      <h4 class="footer-subtitle">快速链接</h4>
      <ul class="footer-links">
        <li><a href={`${BASE_URL || '/'}news`}>新闻动态</a></li>
        <li><a href={`${BASE_URL || '/'}blog`}>技术博客</a></li>
        <li><a href={`${BASE_URL || '/'}services`}>服务项目</a></li>
        <li><a href="https://github.com/BITNP" target="_blank" rel="noopener noreferrer">GitHub</a></li>
      </ul>
    </div>
    
    <div class="footer-section">
      <h4 class="footer-subtitle">联系我们</h4>
      <ul class="footer-contact">
        <li>B站: 网络开拓者</li>
        <li>微信: bitwangxie</li>
        <li>© 2026 BITNP 网络技术协会</li>
      </ul>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p class="footer-copyright">
      Copyright © 1997–2026 Net Pioneer Association of BIT All Rights Reserved. Contact us: webmaster AT bitnp.net 
    </p>
  </div>
</footer>

