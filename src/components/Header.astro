---
// Header 组件
// 导入图片资源和 Astro Image 组件
import icon from '../assets/icon.png';
import user from '../assets/user.svg';
import github from '../assets/github.svg';
import share from '../assets/share-2.svg';
import newsIcon from '../assets/news.svg';
import blogIcon from '../assets/blog.svg';
import serviceIcon from '../assets/service.svg';
import { Image } from 'astro:assets';
import ThemeToggle from './ThemeToggle.astro';
import '../styles/components/header.css';

const BASE_URL = import.meta.env.BASE_URL;
---

<header class="header">
  <!-- 左侧部分：Logo + 导航 -->
  <div class="header-left">
    <!-- 社团 Logo -->
    <a href={BASE_URL || '/'} class="logo">
      <Image 
        src={icon} 
        alt="BITNP Logo" 
        width={40}
        height={40}
        loading={'eager'}
        class="logo-image"
      />
    </a>
    
    <!-- Logo 右侧的较大 margin -->
    <div class="logo-margin"></div>
    
    <!-- 导航菜单 -->
    <nav class="nav-menu">
      <a href={`${BASE_URL || '/'}news`} class="nav-item">
        <Image src={newsIcon} alt="新闻" width={20} height={20} class="nav-icon" loading={'eager'} />
        <span class="nav-text">新闻</span>
      </a>
      <a href={`${BASE_URL || '/'}blog`} class="nav-item">
        <Image src={blogIcon} alt="博客" width={20} height={20} class="nav-icon" loading={'eager'} />
        <span class="nav-text">博客</span>
      </a>
      <a href={`${BASE_URL || '/'}services`} class="nav-item">
        <Image src={serviceIcon} alt="服务" width={20} height={20} class="nav-icon" loading={'eager'} />
        <span class="nav-text">服务</span>
      </a>
    </nav>
  </div>
  
  <!-- 右侧部分：功能图标 -->
  <div class="header-right">
    <!-- 亮/暗模式切换开关组件 -->
    <ThemeToggle />
    
    <!-- 用户登录模式 -->
    <button class="icon-button" aria-label="用户登录">
      <Image 
        src={user} 
        alt="用户登录" 
        width={20}
        height={20}
        loading={'eager'}
        class="icon-image"
      />
    </button>
    
    <!-- 社团 GitHub 账号 -->
    <a 
      href="https://github.com/BITNP" 
      class="icon-button" 
      aria-label="GitHub" 
      target="_blank"
      rel="noopener noreferrer"
    >
      <Image 
        src={github} 
        alt="GitHub" 
        width={20}
        height={20}
        loading={'eager'}
        class="icon-image"
      />
    </a>
    
    <!-- 网站分享 -->
    <button class="icon-button" aria-label="分享网站">
      <Image 
        src={share} 
        alt="分享" 
        width={20}
        height={20}
        loading={'eager'}
        class="icon-image"
      />
    </button>
  </div>
</header>

