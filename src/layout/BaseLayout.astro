---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/layout/base-layout.css';

interface Props {
  title?: string;
  description?: string;
  fullWidth?: boolean;
  showFooter?: boolean;
}

const { 
  title = 'BITNP-Website', 
  description = '北京理工大学网络开拓者协会官方网站',
  fullWidth = false,
  showFooter = true
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content={description}>
        <title>{title}</title>

    </head>
    <body>
        <Header />
        <main class={fullWidth ? 'main-fullwidth' : ''}>
            <slot />
        </main>
        {showFooter ? <Footer /> : null}
    </body>
</html>
